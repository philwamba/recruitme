# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_ENV="development"

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/recruitme"

# Auth
AUTH_SECRET="replace-with-a-long-random-string-at-least-32-characters"
SESSION_COOKIE_NAME="recruitme_session"
SESSION_TTL_HOURS="168"

# Cloudflare R2 Storage
CLOUDFLARE_ACCOUNT_ID="your_account_id"
CLOUDFLARE_R2_ACCESS_KEY_ID="your_access_key_id"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="your_secret_access_key"
CLOUDFLARE_R2_BUCKET_NAME="recruitme-uploads"
CLOUDFLARE_R2_PUBLIC_URL="https://your-bucket.r2.cloudflarestorage.com"

# CV Parser API
CV_PARSER_API_KEY=""
CV_PARSER_API_URL=""

# Observability
OBSERVABILITY_WEBHOOK_URL=""

# Email Delivery
EMAIL_PROVIDER="log"
EMAIL_FROM="RecruitMe <no-reply@example.com>"
RESEND_API_KEY=""

# Private File Storage
PRIVATE_STORAGE_DRIVER="local"
PRIVATE_FILES_ROOT="/tmp/recruitme-private-files"

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
LINKEDIN_REDIRECT_URI="http://localhost:3000/api/auth/linkedin/callback"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# Redis
REDIS_URL=""

# ClamAV
CLAMAV_HOST=""
CLAMAV_PORT="3310"
