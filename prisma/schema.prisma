datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Enums
enum UserRole {
  ADMIN
  EMPLOYER
  APPLICANT
}

enum Permission {
  VIEW_APPLICANT_DASHBOARD
  MANAGE_SELF_PROFILE
  MANAGE_JOBS
  MANAGE_APPLICATIONS
  MANAGE_USERS
  VIEW_AUDIT_LOGS
  MANAGE_SYSTEM_SETTINGS
  VIEW_ANALYTICS
  MANAGE_NOTIFICATIONS
  MANAGE_COMPLIANCE
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  SHORTLISTED
  INTERVIEW_PHASE_1
  INTERVIEW_PHASE_2
  ASSESSMENT
  OFFER
  REJECTED
  HIRED
  WITHDRAWN
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  TEMPORARY
}

enum WorkplaceType {
  REMOTE
  HYBRID
  ONSITE
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum DocumentType {
  CV
  SUPPORTING_DOCUMENT
}

enum DocumentScanStatus {
  PENDING
  CLEAN
  REJECTED
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum InterviewParticipantRole {
  INTERVIEWER
  COORDINATOR
  OBSERVER
}

enum Recommendation {
  STRONG_YES
  YES
  MAYBE
  NO
  STRONG_NO
}

enum AssessmentStatus {
  ASSIGNED
  SUBMITTED
  REVIEWED
  CANCELLED
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum DeliveryStatus {
  QUEUED
  SENT
  FAILED
}

enum OutboxJobType {
  SEND_NOTIFICATION
  SEND_STAGE_NOTIFICATION
  SEND_INTERVIEW_INVITATION
  SEND_ASSESSMENT_INVITATION
}

enum OutboxJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ConsentType {
  APPLICATION_PROCESSING
  EMAIL_COMMUNICATION
  DATA_RETENTION
}

enum DataDeletionRequestStatus {
  REQUESTED
  IN_PROGRESS
  COMPLETED
  FAILED
  REJECTED
}

enum AuthSecurityEventType {
  SIGN_IN_SUCCEEDED
  SIGN_IN_FAILED
  SIGN_OUT_SUCCEEDED
  ACCOUNT_LOCKED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  EMAIL_VERIFICATION_REQUESTED
  EMAIL_VERIFIED
  UNAUTHORIZED_ACCESS_ATTEMPT
}

// Existing model
model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

// User model
model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  googleId             String?   @unique
  linkedinId           String?   @unique
  emailVerified        DateTime?
  passwordHash         String?
  role                 UserRole  @default(APPLICANT)
  failedSignInAttempts Int       @default(0)
  lockedUntil          DateTime?
  lastSignInAt         DateTime?
  passwordChangedAt    DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  applicantProfile ApplicantProfile?
  applications     Application[]
  sessions         Session[]
  verificationTokens VerificationToken[]
  passwordResetTokens PasswordResetToken[]
  authSecurityEvents AuthSecurityEvent[]
  auditLogsAsActor  AuditLog[] @relation("AuditActor")
  activityLogsAsActor ActivityLog[] @relation("ActivityActor")
  jobsCreated       Job[] @relation("JobCreator")
  applicationNotes  ApplicationNote[]
  applicationStageEvents ApplicationStageEvent[] @relation("StageChangedBy")
  applicationRatings ApplicationRating[]
  candidateDocuments CandidateDocument[]
  interviewsCreated  Interview[] @relation("InterviewCreator")
  interviewParticipants InterviewParticipant[]
  interviewFeedbacks InterviewFeedback[]
  assessmentsCreated Assessment[] @relation("AssessmentCreator")
  assessmentSubmissions AssessmentSubmission[]
  notifications Notification[]
  emailTemplatesCreated EmailTemplate[] @relation("EmailTemplateCreator")
  consentRecords ConsentRecord[]
  deletionRequests DataDeletionRequest[]
  savedSearches SavedSearch[]
  candidateImports CandidateImport[] @relation("CandidateImporter")
}

model RolePermission {
  id         String     @id @default(cuid())
  role       UserRole
  permission Permission
  createdAt  DateTime   @default(now())

  @@unique([role, permission])
  @@index([role])
}

model Session {
  id               String   @id @default(cuid())
  sessionTokenHash String   @unique
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt        DateTime
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime @default(now())
  lastUsedAt       DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AuthSecurityEvent {
  id        String                @id @default(cuid())
  userId    String?
  user      User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  type      AuthSecurityEventType
  email     String?
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime              @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorUserId String?
  actor      User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  action     String
  targetType String
  targetId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([actorUserId])
  @@index([action])
  @@index([createdAt])
}

model ActivityLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actor       User?    @relation("ActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  description String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([actorUserId])
  @@index([createdAt])
}

// Applicant Profile
model ApplicantProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Personal Information
  firstName String?
  lastName  String?
  phone     String?
  city      String?
  country   String?
  avatarUrl String?

  // Links
  linkedinUrl  String?
  githubUrl    String?
  portfolioUrl String?

  // Professional Summary
  headline String?
  bio      String? @db.Text

  // Skills (PostgreSQL array)
  skills String[]

  // CV
  cvUrl      String?
  cvFileName String?
  cvParsedAt DateTime?

  // Computed fields
  totalYearsExperience Float?
  profileCompleteness  Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  workExperiences WorkExperience[]
  educations      Education[]
  certifications  Certification[]
  candidateDocuments CandidateDocument[]
}

// Work Experience
model WorkExperience {
  id                 String           @id @default(cuid())
  applicantProfileId String
  applicantProfile   ApplicantProfile @relation(fields: [applicantProfileId], references: [id], onDelete: Cascade)

  company     String
  role        String
  location    String?
  startDate   DateTime
  endDate     DateTime?
  isCurrent   Boolean   @default(false)
  description String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([applicantProfileId])
}

// Education
model Education {
  id                 String           @id @default(cuid())
  applicantProfileId String
  applicantProfile   ApplicantProfile @relation(fields: [applicantProfileId], references: [id], onDelete: Cascade)

  institution  String
  degree       String
  fieldOfStudy String?
  startDate    DateTime?
  endDate      DateTime?
  description  String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([applicantProfileId])
}

// Certification
model Certification {
  id                 String           @id @default(cuid())
  applicantProfileId String
  applicantProfile   ApplicantProfile @relation(fields: [applicantProfileId], references: [id], onDelete: Cascade)

  name           String
  issuingOrg     String?
  issueDate      DateTime?
  expirationDate DateTime?
  credentialUrl  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([applicantProfileId])
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs Job[]
}

// Master Data: Job Classification
model JobCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique
  description String?  @db.Text
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jobTitles JobTitle[]
  jobs      Job[]

  @@index([isActive])
}

model JobTitle {
  id          String       @id @default(cuid())
  name        String
  code        String       @unique
  categoryId  String
  category    JobCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  description String?      @db.Text
  rankGradeId String?
  rankGrade   RankGrade?   @relation(fields: [rankGradeId], references: [id], onDelete: SetNull)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  jobs Job[]

  @@index([categoryId])
  @@index([rankGradeId])
  @@index([isActive])
}

model RankGrade {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  level       Int
  description String?  @db.Text
  minSalary   Int?
  maxSalary   Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jobTitles JobTitle[]

  @@index([level])
  @@index([isActive])
}

// Master Data: Qualities/Factors for Evaluation
model Quality {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?  @db.Text
  category    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  templateItems QualityTemplateItem[]

  @@index([category])
  @@index([isActive])
}

model QualityTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  qualities QualityTemplateItem[]
  jobs      Job[]

  @@index([isActive])
}

model QualityTemplateItem {
  id         String          @id @default(cuid())
  templateId String
  template   QualityTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  qualityId  String
  quality    Quality         @relation(fields: [qualityId], references: [id], onDelete: Restrict)
  weight     Float           @default(1.0)
  isRequired Boolean         @default(true)
  sortOrder  Int             @default(0)

  @@unique([templateId, qualityId])
  @@index([templateId])
  @@index([qualityId])
}

// Job posting
model Job {
  id             String         @id @default(cuid())
  slug           String         @unique
  title          String
  company        String
  location       String?
  description    String         @db.Text
  requirements   String?        @db.Text
  benefits       String?        @db.Text
  salaryMin      Int?
  salaryMax      Int?
  salaryCurrency String?
  employmentType EmploymentType
  workplaceType  WorkplaceType
  status         JobStatus      @default(DRAFT)
  departmentId   String?
  department     Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  // Master data references
  categoryId     String?
  category       JobCategory?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  jobTitleId     String?
  jobTitle       JobTitle?      @relation(fields: [jobTitleId], references: [id], onDelete: SetNull)
  qualityTemplateId String?
  qualityTemplate   QualityTemplate? @relation(fields: [qualityTemplateId], references: [id], onDelete: SetNull)
  createdByUserId String?
  createdBy      User?          @relation("JobCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  publishedAt    DateTime?
  expiresAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  applications   Application[]
  pipelineStages JobPipelineStage[]
  assessments    Assessment[]
  emailTemplates EmailTemplate[]
  candidateImports CandidateImport[]

  @@index([status, publishedAt])
  @@index([departmentId])
  @@index([categoryId])
  @@index([jobTitleId])
  @@index([qualityTemplateId])
  @@index([employmentType, workplaceType])
}

// Job Application
model Application {
  id             String            @id @default(cuid())
  trackingId     String            @unique
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId          String
  job            Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status         ApplicationStatus @default(DRAFT)
  currentStageId String?
  currentStage   JobPipelineStage? @relation("CurrentApplicationStage", fields: [currentStageId], references: [id], onDelete: SetNull)
  coverLetter    String?           @db.Text
  source         String?
  consentAcceptedAt DateTime?
  submittedAt    DateTime?
  appliedAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  stageEvents    ApplicationStageEvent[]
  notes          ApplicationNote[]
  tags           ApplicationTag[]
  ratings        ApplicationRating[]
  documents      CandidateDocument[]
  interviews     Interview[]
  interviewFeedbacks InterviewFeedback[]
  assessments    Assessment[]
  notifications  Notification[]
  consentRecords ConsentRecord[]

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
  @@index([status, currentStageId])
}

model JobPipelineStage {
  id          String       @id @default(cuid())
  jobId        String
  job         Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  name        String
  order       Int
  isDefault   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  applications       Application[] @relation("CurrentApplicationStage")
  stageEventsFrom    ApplicationStageEvent[] @relation("StageEventFrom")
  stageEventsTo      ApplicationStageEvent[] @relation("StageEventTo")

  @@unique([jobId, order])
  @@index([jobId])
}

model ApplicationStageEvent {
  id            String            @id @default(cuid())
  applicationId String
  application   Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  fromStageId   String?
  fromStage     JobPipelineStage? @relation("StageEventFrom", fields: [fromStageId], references: [id], onDelete: SetNull)
  toStageId     String?
  toStage       JobPipelineStage? @relation("StageEventTo", fields: [toStageId], references: [id], onDelete: SetNull)
  changedByUserId String?
  changedBy     User?             @relation("StageChangedBy", fields: [changedByUserId], references: [id], onDelete: SetNull)
  note          String?           @db.Text
  createdAt     DateTime          @default(now())

  @@index([applicationId])
  @@index([changedByUserId])
}

model ApplicationNote {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  authorUserId  String
  author        User        @relation(fields: [authorUserId], references: [id], onDelete: Cascade)
  body          String      @db.Text
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([applicationId])
  @@index([authorUserId])
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applicationTags ApplicationTag[]
}

model ApplicationTag {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  tagId         String
  tag           Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([applicationId, tagId])
  @@index([tagId])
}

model ApplicationRating {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  authorUserId  String
  author        User        @relation(fields: [authorUserId], references: [id], onDelete: Cascade)
  score         Int
  comment       String?     @db.Text
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([applicationId])
  @@index([authorUserId])
}

model CandidateDocument {
  id                 String             @id @default(cuid())
  applicationId      String?
  application        Application?       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicantProfileId String?
  applicantProfile   ApplicantProfile?  @relation(fields: [applicantProfileId], references: [id], onDelete: Cascade)
  uploadedByUserId   String
  uploadedByUser     User               @relation(fields: [uploadedByUserId], references: [id], onDelete: Cascade)
  documentType       DocumentType
  storageKey         String             @unique
  originalFileName   String
  mimeType           String
  sizeBytes          Int
  sha256             String
  scanStatus         DocumentScanStatus @default(PENDING)
  isPrivate          Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([applicationId])
  @@index([applicantProfileId])
  @@index([uploadedByUserId])
}

model Interview {
  id              String           @id @default(cuid())
  applicationId   String
  application     Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  title           String
  scheduledAt     DateTime
  durationMinutes Int              @default(60)
  timezone        String
  location        String?
  meetingUrl      String?
  status          InterviewStatus  @default(SCHEDULED)
  notes           String?          @db.Text
  createdByUserId String?
  createdBy       User?            @relation("InterviewCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  participants InterviewParticipant[]
  feedbacks    InterviewFeedback[]

  @@index([applicationId])
  @@index([scheduledAt])
}

model InterviewParticipant {
  id          String                   @id @default(cuid())
  interviewId String
  interview   Interview                @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?                    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email       String
  role        InterviewParticipantRole
  createdAt   DateTime                 @default(now())

  @@index([interviewId])
  @@index([userId])
}

model InterviewFeedback {
  id            String         @id @default(cuid())
  interviewId   String
  interview     Interview      @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  applicationId String
  application   Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  authorUserId  String
  author        User           @relation(fields: [authorUserId], references: [id], onDelete: Cascade)
  score         Int
  recommendation Recommendation
  comments      String?        @db.Text
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([interviewId])
  @@index([applicationId])
  @@index([authorUserId])
}

model Assessment {
  id              String           @id @default(cuid())
  jobId           String?
  job             Job?             @relation(fields: [jobId], references: [id], onDelete: SetNull)
  applicationId   String
  application     Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  title           String
  instructions    String           @db.Text
  dueAt           DateTime?
  status          AssessmentStatus @default(ASSIGNED)
  createdByUserId String?
  createdBy       User?            @relation("AssessmentCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  submissions AssessmentSubmission[]

  @@index([applicationId])
  @@index([jobId])
}

model AssessmentSubmission {
  id              String      @id @default(cuid())
  assessmentId    String
  assessment      Assessment  @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  applicantUserId String
  applicantUser   User        @relation(fields: [applicantUserId], references: [id], onDelete: Cascade)
  responseText    String?     @db.Text
  score           Int?
  reviewerNotes   String?     @db.Text
  submittedAt     DateTime?
  reviewedAt      DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([assessmentId, applicantUserId])
  @@index([assessmentId])
  @@index([applicantUserId])
}

model EmailTemplate {
  id              String   @id @default(cuid())
  name            String   @unique
  jobId           String?
  job             Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)
  subject         String
  body            String   @db.Text
  isActive        Boolean  @default(true)
  createdByUserId String?
  createdBy       User?    @relation("EmailTemplateCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  notifications Notification[]

  @@index([jobId])
}

model Notification {
  id            String             @id @default(cuid())
  userId        String
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  applicationId String?
  application   Application?       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  templateId    String?
  template      EmailTemplate?     @relation(fields: [templateId], references: [id], onDelete: SetNull)
  channel       NotificationChannel
  status        NotificationStatus @default(PENDING)
  subject       String
  body          String             @db.Text
  readAt        DateTime?
  sentAt        DateTime?
  metadata      Json?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  deliveryLogs DeliveryLog[]

  @@index([userId, status])
  @@index([applicationId])
}

model DeliveryLog {
  id             String         @id @default(cuid())
  notificationId String
  notification   Notification   @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  provider       String
  status         DeliveryStatus
  responseCode   String?
  responseBody   String?        @db.Text
  attemptedAt    DateTime       @default(now())

  @@index([notificationId])
}

model OutboxJob {
  id          String         @id @default(cuid())
  type        OutboxJobType
  payload     Json
  status      OutboxJobStatus @default(PENDING)
  availableAt DateTime       @default(now())
  processedAt DateTime?
  attempts    Int            @default(0)
  lastError   String?        @db.Text
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status, availableAt])
}

model ConsentRecord {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  applicationId String?
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  consentType   ConsentType
  grantedAt     DateTime    @default(now())
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime    @default(now())

  @@index([userId, consentType])
  @@index([applicationId])
}

model DataDeletionRequest {
  id            String                    @id @default(cuid())
  userId        String
  user          User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status        DataDeletionRequestStatus @default(REQUESTED)
  reason        String?                   @db.Text
  requestedAt   DateTime                  @default(now())
  processedAt   DateTime?
  notes         String?                   @db.Text
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  @@index([userId, status])
}

// Saved searches for candidate search
model SavedSearch {
  id        String   @id @default(cuid())
  name      String
  filters   Json
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Candidate bulk import
enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL
}

model CandidateImport {
  id            String       @id @default(cuid())
  fileName      String
  storageKey    String       @unique
  totalRows     Int
  processedRows Int          @default(0)
  successCount  Int          @default(0)
  errorCount    Int          @default(0)
  status        ImportStatus @default(PENDING)
  errors        Json?        // Array of { row: number, field: string, message: string }
  fieldMapping  Json?        // { csvColumn: fieldName }
  importedById  String
  importedBy    User         @relation("CandidateImporter", fields: [importedById], references: [id])
  jobId         String?
  job           Job?         @relation(fields: [jobId], references: [id], onDelete: SetNull)
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime     @default(now())

  @@index([status])
  @@index([importedById])
}
